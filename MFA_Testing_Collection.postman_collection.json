			"name": "6. Rate Limiting Tests",
			"item": [
				{
					"name": "Multiple Failed TOTP Attempts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// This test should be run multiple times to test rate limiting",
									"pm.test(\"Rate limiting enforced\", function () {",
									"    const iteration = pm.variables.get(\"iteration\") || 1;",
									"    ",
									"    if (iteration <= 5) {",
									"        // First 5 attempts should return 400",
									"        pm.response.to.have.status(400);",
									"    } else {",
									"        // 6th attempt should be rate limited",
									"        pm.response.to.have.status(429);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Track iteration count",
									"let iteration = pm.variables.get(\"iteration\") || 1;",
									"pm.variables.set(\"iteration\", iteration + 1);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
