			"name": "4. Recovery Code Management",
			"item": [
				{
					"name": "Get Recovery Codes",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Recovery codes list returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result).to.have.property('codes');",
									"    pm.expect(jsonData.result).to.have.property('total');",
									"    pm.expect(jsonData.result).to.have.property('unusedCount');",
									"    pm.expect(jsonData.result.codes).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Used recovery code marked\", function () {",
									"    var jsonData = pm.response.json();",
									"    const usedCode = jsonData.result.codes.find(c => c.used === true);",
									"    pm.expect(usedCode).to.not.be.undefined;",
									"    pm.expect(usedCode.usedAt).to.not.be.null;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
