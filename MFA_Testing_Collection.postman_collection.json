{
	"info": {
		"_postman_id": "mfa-testing-collection",
		"name": "MindLogger MFA Testing Collection",
		"description": "Comprehensive test collection for Multi-Factor Authentication implementation in MindLogger backend",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [{
			"key": "token",
			"value": "{{access_token}}",
			"type": "string"
		}]
	},
	"item": [
		{
			"name": "1. User Registration & Authentication",
			"item": [
				{
					"name": "Register New User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has user data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result).to.have.property('id');",
									"    pm.expect(jsonData.result.mfaEnabled).to.equal(false);",
									"    pm.collectionVariables.set(\"user_id\", jsonData.result.id);",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate unique test user",
									"const timestamp = new Date().getTime();",
									"pm.collectionVariables.set(\"test_email\", `mfa.test.${timestamp}@example.com`);",
									"pm.collectionVariables.set(\"test_password\", \"TestPassword123!\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"firstName\": \"MFA\",\n    \"lastName\": \"Test\",\n    \"password\": \"{{test_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login Without MFA",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has tokens\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result.token).to.have.property('accessToken');",
									"    pm.expect(jsonData.result.token).to.have.property('refreshToken');",
									"    pm.collectionVariables.set(\"access_token\", jsonData.result.token.accessToken);",
									"    pm.collectionVariables.set(\"refresh_token\", jsonData.result.token.refreshToken);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\",\n    \"deviceId\": \"test-device-001\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. MFA Enrollment",
			"item": [
				{
					"name": "Initiate MFA Setup",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has provisioning URI\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result).to.have.property('provisioningUri');",
									"    pm.expect(jsonData.result).to.have.property('message');",
									"    pm.collectionVariables.set(\"provisioning_uri\", jsonData.result.provisioningUri);",
									"    ",
									"    // Extract secret from URI for testing",
									"    const uri = jsonData.result.provisioningUri;",
									"    const secretMatch = uri.match(/secret=([A-Z0-9]+)/);",
									"    if (secretMatch) {",
									"        pm.collectionVariables.set(\"totp_secret\", secretMatch[1]);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/users/me/mfa/totp/initiate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"me",
								"mfa",
								"totp",
								"initiate"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify TOTP Setup (Invalid Code)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test(\"Error message for invalid TOTP\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result[0].message).to.include(\"Invalid TOTP code\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/me/mfa/totp/verify",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"me",
								"mfa",
								"totp",
								"verify"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify TOTP Setup (Valid Code)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Note: In actual testing, you need to generate a valid TOTP code",
									"// Using a tool like oathtool or Google Authenticator with the secret",
									"// For automated testing, you would need to integrate a TOTP library",
									"",
									"// Example: oathtool --base32 --totp \"{{totp_secret}}\"",
									"// Then manually set the generated code:",
									"// pm.collectionVariables.set(\"current_totp_code\", \"generated_code\");"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"MFA enabled successfully\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result.mfaEnabled).to.equal(true);",
									"    pm.expect(jsonData.result.message).to.include(\"successfully enabled\");",
									"});",
									"",
									"pm.test(\"Recovery codes returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result).to.have.property('recoveryCodes');",
									"    pm.expect(jsonData.result.recoveryCodes).to.be.an('array');",
									"    pm.expect(jsonData.result.recoveryCodes.length).to.equal(10);",
									"    ",
									"    // Store recovery codes for later tests",
									"    if (jsonData.result.recoveryCodes && jsonData.result.recoveryCodes.length > 0) {",
									"        pm.collectionVariables.set(\"recovery_code_1\", jsonData.result.recoveryCodes[0]);",
									"        pm.collectionVariables.set(\"recovery_code_2\", jsonData.result.recoveryCodes[1]);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"{{current_totp_code}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/me/mfa/totp/verify",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"me",
								"mfa",
								"totp",
								"verify"
							]
						}
					},
					"response": []
				}
			]
		},
